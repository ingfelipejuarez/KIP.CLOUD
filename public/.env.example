# ═══════════════════════════════════════════════════════════════════
# KIP · .env.example
# ═══════════════════════════════════════════════════════════════════
#
# Copia este archivo como .env y rellena los valores reales.
# NUNCA commitees el archivo .env — ya está en .gitignore.
#
# Uso:
#   cp .env.example .env
#   # Edita .env con tus valores reales
#
# En Vercel: Dashboard → Settings → Environment Variables
# En Netlify: Site Settings → Build & Deploy → Environment
# En producción: variables de entorno del sistema operativo
# ═══════════════════════════════════════════════════════════════════


# ── Modo de operación ───────────────────────────────────────────────
# true  → conecta al backend real
# false → modo mock (desarrollo sin backend)
VITE_KIP_USE_REAL_API=false


# ── Backend API ─────────────────────────────────────────────────────
# URL base del backend (sin slash final)
# Ejemplos:
#   Desarrollo:  /api/v1
#   Producción:  https://api.kip.app/v1
VITE_KIP_API_BASE=/api/v1


# ── DeepSeek AI ─────────────────────────────────────────────────────
# API Key de DeepSeek para el chat de IA personal.
# Obtén tu clave en: https://platform.deepseek.com/api_keys
#
# ⚠ NUNCA expongas esta clave en el frontend de producción.
#   En producción, las peticiones a DeepSeek deben pasar por
#   tu backend, que actúa como proxy y protege la clave.
#   Solo úsala directamente en el frontend para desarrollo local.
VITE_KIP_DEEPSEEK_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Modelo de DeepSeek ──────────────────────────────────────────────
# deepseek-chat     → DeepSeek-V4 (recomendado)
# deepseek-reasoner → DeepSeek-R2 (más lento, para análisis profundo)
VITE_KIP_DEEPSEEK_MODEL=deepseek-chat


# ── Feature flags ───────────────────────────────────────────────────
# true  → IA requiere plan Premium
# false → IA disponible para todos (desarrollo / beta)
VITE_KIP_AI_REQUIRES_PREMIUM=false


# ── Stripe (pagos) ──────────────────────────────────────────────────
# Clave pública de Stripe (publishable key — esta SÍ puede ir en frontend)
# NUNCA pongas aquí la secret key de Stripe
# VITE_KIP_STRIPE_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx


# ── Analytics (opcional) ────────────────────────────────────────────
# VITE_KIP_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
# VITE_KIP_POSTHOG_HOST=https://app.posthog.com
