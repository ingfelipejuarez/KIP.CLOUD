# KIP — Variables de entorno del monolito
# En Railway: añade estas en Settings → Variables
# En local:   copia a .env y rellena

# ── Base de datos ──────────────────────────────────────────────────
# Railway la genera automáticamente al añadir el plugin PostgreSQL
DATABASE_URL="postgresql://user:pass@host:5432/kip_db"

# ── JWT ───────────────────────────────────────────────────────────
# Genera en terminal: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CAMBIA_ESTO_POR_64_BYTES_ALEATORIOS"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ── Servidor ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV="production"

# ── Cookie ────────────────────────────────────────────────────────
COOKIE_SECURE="true"
COOKIE_DOMAIN=""

# ── IA — DeepSeek ─────────────────────────────────────────────────
DEEPSEEK_API_KEY="sk-..."
DEEPSEEK_MODEL="deepseek-chat"
AI_MAX_TOKENS=1024
AI_TEMPERATURE=0.7
AI_REQUIRES_PREMIUM=false

# ── Rate limiting ─────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
LOGIN_RATE_LIMIT_MAX=10
AI_RATE_LIMIT_MAX=30
